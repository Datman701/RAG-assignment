# Google Gemini API Key (required for LLM)
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model to use (optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Hugging Face Embedding Model (optional, defaults to sentence-transformers/all-MiniLM-L6-v2)
# Other popular options: sentence-transformers/all-mpnet-base-v2, sentence-transformers/paraphrase-MiniLM-L6-v2
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: Log level for debugging
LOG_LEVEL=INFO

# Optional: Maximum file upload size (bytes, default: 10MB)
MAX_UPLOAD_SIZE=10485760
